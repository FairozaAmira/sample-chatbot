# Production environment configuration
CHATBOT_APP_NAME="Enterprise RAG Chatbot"
CHATBOT_APP_ENV="production"

# LLM configuration
# Provider options: placeholder | openai | ollama
CHATBOT_LLM_PROVIDER="placeholder"
# set if using openai provider
CHATBOT_LLM_API_KEY=""
CHATBOT_LLM_MODEL="llama3.2"
CHATBOT_OLLAMA_BASE_URL="http://127.0.0.1:11434"
CHATBOT_OLLAMA_TIMEOUT_SECONDS=300
CHATBOT_LLM_COST_PER_1K_TOKENS=0.0
CHATBOT_ENABLE_DEEPEVAL=false

# Chroma telemetry
ANONYMIZED_TELEMETRY=False

# Storage locations
CHATBOT_CHROMA_PERSIST_DIRECTORY=.chroma_store
CHATBOT_DATA_DIRECTORY=data
CHATBOT_QA_CACHE_DIRECTORY=generated_qa
